# ==============================================================================
# LLM Quantization Lab — .gitignore
# ==============================================================================

# ── Model files (large binaries — NEVER commit these) ────────────────────────
models/
!models/.gitkeep
!models/**/.gitkeep

# ── llama.cpp (cloned & built automatically by the pipeline) ─────────────────
llama.cpp/

# ── Benchmark results (generated per-run, not portable) ──────────────────────
results/benchmark_results.json
results/*.png
results/*.svg

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual environments ────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Jupyter / IPython ───────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE / Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ── OS junk ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Misc ────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
